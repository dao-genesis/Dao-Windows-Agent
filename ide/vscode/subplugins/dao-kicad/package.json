{
  "name": "dao-kicad",
  "displayName": "DAO KiCad — 归一 PCB 工作台",
  "description": "KiCad in your IDE: schematic/PCB viewing, netlist→board build, freerouting autoroute, DRC/ERC and fab outputs — all bridged to the daokicad engine, no KiCad GUI needed.",
  "version": "0.5.0",
  "publisher": "dao",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "daoKicad.openHome",
        "title": "DAO KiCad: 打开归一主页 (Open Home)"
      },
      {
        "command": "daoKicad.openChat",
        "title": "DAO KiCad: 打开道之对话 (Open Chat)"
      },
      {
        "command": "daoKicad.restartBridge",
        "title": "DAO KiCad: 重启桥接服务 (Restart Bridge)"
      },
      {
        "command": "daoKicad.mountEngine",
        "title": "DAO KiCad: 挂载 KiCad 底座引擎 (Mount Engine)"
      },
      {
        "command": "daoKicad.modeToggle",
        "title": "DAO KiCad: 切换 KiCad 模式 / 原生模式 (Toggle Mode)"
      },
      {
        "command": "daoKicad.cascade.open",
        "title": "KiCad · AI: 聚焦 Cascade 三模式面板"
      },
      {
        "command": "daoKicad.cascade.newSession",
        "title": "KiCad · AI: 新建 Cascade 会话",
        "icon": "$(add)"
      },
      {
        "command": "daoKicad.cascade.history",
        "title": "KiCad · AI: Cascade 历史会话",
        "icon": "$(history)"
      },
      {
        "command": "daoKicad.cascade.deepwiki",
        "title": "KiCad · AI: DeepWiki 解释选中符号"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "daoKicad",
          "title": "DAO KiCad",
          "icon": "media/dao.svg"
        },
        {
          "id": "daoKicad-cascade",
          "title": "KiCad · AI",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "daoKicad": [
        {
          "type": "webview",
          "id": "daoKicad.chatView",
          "name": "道之对话"
        }
      ],
      "daoKicad-cascade": [
        {
          "id": "daoKicad.cascade",
          "name": "Cascade · 三模式",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "DAO KiCad",
      "properties": {
        "daoKicad.enginePath": {
          "type": "string",
          "default": "",
          "description": "Path to the dao_kicad engine folder (contains daokicad/ and bridge/). Empty = auto-detect in workspace."
        },
        "daoKicad.python": {
          "type": "string",
          "default": "python3",
          "description": "Python interpreter used to run the bridge server."
        },
        "daoKicad.port": {
          "type": "number",
          "default": 9931,
          "description": "Localhost port for the bridge REST service."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "daoKicad.cascade.newSession",
          "when": "view == daoKicad.cascade",
          "group": "navigation@1"
        },
        {
          "command": "daoKicad.cascade.history",
          "when": "view == daoKicad.cascade",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "package": "npx --yes @vscode/vsce package --allow-missing-repository"
  }
}
